# Copy to .env (do not commit .env)
# DATABASE_URL examples:
# - SQLite (local dev): sqlite:///./dev.db
# - Postgres (recommended): postgresql+psycopg2://postgres:postgres@localhost:5432/saas_platform

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/saas_platform
SECRET_KEY=change-me-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=14400
